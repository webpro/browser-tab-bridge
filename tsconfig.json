{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src/lib",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/lib"]
}
