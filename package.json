{
  "name": "browser-tab-bridge",
  "version": "0.1.1",
  "type": "module",
  "description": "Read and control browser tabs from outside the browser (macOS)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webpro/browser-tab-bridge.git"
  },
  "homepage": "https://github.com/webpro/browser-tab-bridge",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "extension",
    "host",
    "scripts"
  ],
  "scripts": {
    "build": "node scripts/build-extensions.mjs && tsc",
    "install:firefox": "node scripts/install-extension.mjs --browser firefox",
    "install:zen": "node scripts/install-extension.mjs --browser zen",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^6.0.2"
  },
  "os": [
    "darwin"
  ],
  "keywords": [
    "open",
    "browser",
    "tab",
    "macos",
    "applescript",
    "native-messaging"
  ],
  "author": {
    "name": "Lars Kappert",
    "email": "lars@webpro.nl"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.33.0"
}
